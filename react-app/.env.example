# React Frontend Environment Variables Template

# API Backend URL
# Must start with REACT_APP_ to be accessible in React
# Update this if backend is deployed on a different host
REACT_APP_API_URL=http://localhost:3000/api

# Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Update REACT_APP_API_URL if your backend runs on a different URL
# 3. Never commit .env to version control
# 4. For production builds, update REACT_APP_API_URL to your deployed backend URL
#    Example: REACT_APP_API_URL=https://api.yourdomain.com/api
